# =============================================================================
# notion-diary-mcp 環境変数テンプレート
# =============================================================================
# 1. このファイルを `.env` にコピー
# 2. 各値を自分の環境に書き換える
# 3. .env は .gitignore に含まれているので、絶対にコミットしないこと
# =============================================================================

# --- Notion Internal Integration Token ---
# 取得方法:
#   1. https://www.notion.so/developers/connections にアクセス
#   2. 「+ 新規コネクト」を作成
#   3. 表示される「アクセストークン」をコピー
# 形式は `ntn_...` または `secret_...` で始まる文字列
NOTION_TOKEN=ntn_..............................................

# --- 日記用データベースの ID ---
# 取得方法:
#   1. Notion で日記用データベースのページを開く
#   2. URL の `https://www.notion.so/{ここの32文字}?v=...` の部分が DB ID
# 例: https://www.notion.so/00000000000000000000000000000000?v=...
#     → 00000000000000000000000000000000
# 重要: 上で作成した Integration にこの DB を「コネクション」で接続すること
NOTION_DIARY_DATABASE_ID=................................

# --- ログレベル（オプション） ---
# trace, debug, info, warn, error から選択。デフォルトは info。
# RUST_LOG=info,notion_diary_mcp=debug

# --- 過去日上限（オプション） ---
# save_diary で書き込み可能な過去日の上限（日数）。
# 0 または未設定で無制限。デフォルトは 0（無制限）。
# DIARY_MAX_PAST_DAYS=0
